generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  IDUsers     Int       @id @default(autoincrement())
  FIO         String
  BirthDate   DateTime  @map("Дата рождения")
  Phone       String    @map("Телефон")
  Email       String    @unique
  Password    String
  IDRoles     Int
  IDJob_title Int
  Orders      Orders[]
  JobTitle    Job_title @relation(fields: [IDJob_title], references: [IDJob_title])
  Role        Roles     @relation(fields: [IDRoles], references: [IDRoles])

  @@map("Users")
}

model Roles {
  IDRoles Int     @id @default(autoincrement())
  Name    String  @map("Наименование")
  Users   Users[]

  @@map("Roles")
}

model Job_title {
  IDJob_title Int     @id @default(autoincrement())
  Name        String  @map("Наименование")
  Users       Users[]

  @@map("Job_title")
}

model Orders {
  IDOrders Int      @id @default(autoincrement())
  Price    Decimal  @map("Цена")
  IDUsers  Int
  IDStatus Int
  Status   Status   @relation(fields: [IDStatus], references: [IDStatus])
  User     Users    @relation(fields: [IDUsers], references: [IDUsers])
  Dishes   Dishes[] @relation("OrdersToDishes")

  @@map("Orders")
}

model Status {
  IDStatus Int      @id @default(autoincrement())
  Name     String   @map("Наименование")
  Orders   Orders[]

  @@map("Status")
}

model Dishes {
  IDDishes     Int                @id @default(autoincrement())
  Name         String             @map("Наименование")
  Price        Decimal            @map("Цена")
  Description  String             @map("Описание")
  IDDish_types Int
  Ingredients  Dish_ingredients[]
  DishType     Dish_types         @relation(fields: [IDDish_types], references: [IDDish_types])
  Orders       Orders[]           @relation("OrdersToDishes")

  @@map("Dishes")
}

model Dish_types {
  IDDish_types Int      @id @default(autoincrement())
  Name         String   @map("Наименование")
  Dishes       Dishes[]

  @@map("Dish_types")
}

model Dish_ingredients {
  IDDish_ingredients Int         @id @default(autoincrement())
  IDDishes           Int
  IDIngredients      Int
  Quantity           Int         @map("Количество")
  Dish               Dishes      @relation(fields: [IDDishes], references: [IDDishes])
  Ingredient         Ingredients @relation(fields: [IDIngredients], references: [IDIngredients])

  @@map("Dish_ingredients")
}

model Ingredients {
  IDIngredients            Int                    @id @default(autoincrement())
  Name                     String                 @map("Наименование")
  Price                    Decimal                @map("Цена")
  IDIngredients_categories Int
  DishIngredients          Dish_ingredients[]
  Category                 Ingredients_categories @relation(fields: [IDIngredients_categories], references: [IDIngredients_categories])

  @@map("Ingredients")
}

model Ingredients_categories {
  IDIngredients_categories Int           @id @default(autoincrement())
  Name                     String        @map("Наименование")
  Ingredients              Ingredients[]

  @@map("Ingredients_categories")
}
